generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── bit7 core models ───────────────────────────────────────────────

model Agent {
  id              String    @id @default(uuid())
  short_id        String    @unique @default(cuid())
  name            String                          // e.g. "NutriBot"
  description     String                          // what this agent does
  system_prompt   String    @db.Text              // LLM system prompt
  capabilities    Json      @default("[]")        // string[] — e.g. ["image_analysis","calorie_tracking"]
  personality     Json?                            // tone, style, language prefs
  original_prompt String    @db.Text              // what the user asked for
  model           String    @default("claude-sonnet-4-20250514") // LLM model to use
  temperature     Float     @default(0.7)
  max_tokens      Int       @default(1024)
  status          String    @default("active")    // active | paused | archived
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  phone_number    PhoneNumber?
  conversations   Conversation[]
  messages        Message[]

  @@index([short_id])
  @@index([status])
  @@index([created_at])
  @@map("agents")
}

model PhoneNumber {
  id              String    @id @default(uuid())
  agent_id        String    @unique
  phone_number    String    @unique               // E.164 format: +15551234567
  twilio_sid      String    @unique               // Twilio phone number SID
  friendly_name   String?                          // formatted display name
  status          String    @default("active")    // active | released
  provisioned_at  DateTime  @default(now())
  released_at     DateTime?

  agent           Agent     @relation(fields: [agent_id], references: [id], onDelete: Cascade)

  @@index([phone_number])
  @@index([agent_id])
  @@map("phone_numbers")
}

model Conversation {
  id              String    @id @default(uuid())
  agent_id        String
  from_number     String                          // the user's phone number
  started_at      DateTime  @default(now())
  last_message_at DateTime  @default(now())
  message_count   Int       @default(0)
  metadata        Json?                            // any extra context

  agent           Agent     @relation(fields: [agent_id], references: [id], onDelete: Cascade)
  messages        Message[]

  @@unique([agent_id, from_number])              // one conversation per user per agent
  @@index([agent_id, last_message_at])
  @@index([from_number])
  @@map("conversations")
}

model Message {
  id              String    @id @default(uuid())
  conversation_id String
  agent_id        String
  direction       String                          // inbound | outbound
  body            String    @db.Text
  media_urls      Json      @default("[]")        // string[] — MMS image URLs
  twilio_sid      String?                          // Twilio message SID
  tokens_used     Int       @default(0)
  duration_ms     Int       @default(0)
  created_at      DateTime  @default(now())

  conversation    Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  agent           Agent        @relation(fields: [agent_id], references: [id], onDelete: Cascade)

  @@index([conversation_id, created_at])
  @@index([agent_id, created_at])
  @@map("messages")
}

